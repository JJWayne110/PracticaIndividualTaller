<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="25.0"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fitmanage.smartgym.controller.GymController"
      style="-fx-pref-width: 350; -fx-pref-height: 350; -fx-background-color: #f4f4f4;">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="FitManage Telemetry System" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333;"/>

    <Pane fx:id="panelAlerta" style="-fx-background-color: #5cb85c; -fx-background-radius: 10;" prefWidth="300" prefHeight="150">

        <VBox alignment="CENTER" spacing="15.0" layoutX="50.0" layoutY="35.0" prefWidth="200.0">
            <Label fx:id="labelTemp" text="Temperatura: -- °C" style="-fx-font-size: 16px; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label fx:id="labelHum" text="Humedad: -- %" style="-fx-font-size: 16px; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>

    </Pane>
</VBox>